---
import type { MediaValue } from "emdash";
import { getEmDashCollection, getEntryTerms } from "emdash";
import { Image } from "emdash/ui";
import Banner from "../components/Banner.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Shop from "../layouts/Shop.astro";
import { getSiteMeta } from "../lib/site-meta";

const meta = await getSiteMeta();
const { entries: products } = await getEmDashCollection("products");

// Homepage journal preview cap. The bento layout only has room for 3
// cards, but we don't want to show more than the editor's configured
// posts-per-page either, so cap at the smaller of the two.
const journalCap = Math.min(3, meta.postsPerPage);

// ── Journal posts (homepage preview) ──
// We show the three most recent posts in the "From the journal" section.
// If the posts collection hasn't been seeded yet (fresh install), this
// quietly returns nothing and the section is skipped.
let journalPosts: Array<{
  href: string;
  title: string;
  excerpt: string;
  cover: string | MediaValue | null;
  gradient: string;
  date: string;
  minutes: number;
  category: string;
}> = [];
try {
  const { entries: posts } = await getEmDashCollection("posts", {
    status: "published",
  });
  const jfmtDate = (raw: string | Date | undefined | null) => {
    if (!raw) return "";
    const d = raw instanceof Date ? raw : new Date(raw);
    if (Number.isNaN(d.getTime())) return "";
    return new Intl.DateTimeFormat("en-GB", {
      day: "numeric",
      month: "short",
      year: "numeric",
    }).format(d);
  };
  const sortKey = (p: (typeof posts)[number]) =>
    p.data.published_date ?? p.data.publishedAt?.toISOString() ?? "";
  const top = posts
    .slice()
    .sort((a, b) => sortKey(b).localeCompare(sortKey(a)))
    .slice(0, journalCap);
  journalPosts = await Promise.all(
    top.map(async (p) => {
      const dbId = p.data.id ?? p.id;
      const terms = await getEntryTerms("posts", dbId, "post_category");
      const categoryLabel = terms[0]?.label ?? "Journal";
      return {
        href: `/blog/${p.data.slug ?? p.id}`,
        title: p.data.title ?? "",
        excerpt: p.data.excerpt ?? "",
        cover: p.data.cover_image ?? null,
        gradient:
          p.data.cover_gradient ??
          "linear-gradient(135deg, #2d1800 0%, #0b0b0b 100%)",
        date: jfmtDate(p.data.published_date ?? p.data.publishedAt),
        minutes: p.data.reading_minutes ?? 0,
        category: categoryLabel,
      };
    }),
  );
} catch {
  journalPosts = [];
}

// ── Utilities ──
type PriceMap = Record<string, { amount: number }>;
const fmt = (priceMap?: PriceMap, currency = "USD") => {
  const p = priceMap?.[currency];
  if (!p) return null;
  return new Intl.NumberFormat("en-US", { style: "currency", currency }).format(p.amount / 100);
};

// Product type → gradient for placeholder images
const typeGrad: Record<string, string> = {
  simple:       "linear-gradient(135deg,#2d1800,#4a2c0a)",
  variable:     "linear-gradient(135deg,#1a0f00,#3d2200)",
  grouped:      "linear-gradient(135deg,#1f1400,#3a2800)",
  subscription: "linear-gradient(135deg,#001a0a,#0a2d18)",
  external:     "linear-gradient(135deg,#1a001f,#2d0a38)",
};
const getGrad = (type?: string) =>
  (type && typeGrad[type]) ?? typeGrad.simple;

// ── Product data ──
const featured = products.find((p) => p.data.featured === true) ?? products[0];
const recent   = products.slice(0, 8);

// Pre-compute to avoid TS generics in JSX expressions
const featuredPrice = featured ? fmt(featured.data.prices as PriceMap) : null;
const featuredSlug  = featured ? `/shop/${featured.data.slug ?? featured.id}` : "/shop";
const featuredType  = featured ? String(featured.data.type ?? "product") : "product";
const featuredTitle = featured ? String(featured.data.title ?? "") : "";
const featuredGrad  = featured ? getGrad(String(featured.data.type)) : "";

const recentCards = recent.map((p) => ({
  href:   `/shop/${p.data.slug ?? p.id}`,
  title:  String(p.data.title ?? ""),
  type:   String(p.data.type ?? "simple"),
  price:  fmt(p.data.prices as PriceMap),
  grad:   getGrad(String(p.data.type)),
  isOut:  p.data.stock_status === "outofstock",
  isFeat: Boolean(p.data.featured),
}));

// ── Hero slides ──
// Managed in the admin under Content → Hero Slides. Each slide is a
// published entry in the `hero_slides` content collection; drafts are
// auto-hidden by `getEmDashCollection`. We fall back to a sensible
// default set when the collection is empty (fresh install, no seed) so
// the landing page never boots blank.
type BgType = "gradient" | "image" | "video";
type EmbedKind = "mp4" | "youtube" | "vimeo" | null;

type HeroSlide = {
  eyebrow: string;
  headline: string;
  sub: string;
  cta: { label: string; href: string };
  bgType: BgType;
  bgCss: string;
  bgImage: string | MediaValue | null;
  bgFocal: string;
  bgOverlay: string;
  videoUrl: string;
  videoKind: EmbedKind;
  videoPoster: string | MediaValue | null;
  accent: string;
};

// Parse a pasted URL into a video embed descriptor.
// Accepts:
//  - Direct media URLs (.mp4/.webm/.mov) → rendered as <video>.
//  - youtube.com/watch?v=ID, youtube.com/embed/ID, youtu.be/ID → iframe.
//  - vimeo.com/ID, player.vimeo.com/video/ID → iframe.
function parseVideo(raw: string): { kind: EmbedKind; src: string } {
  const url = raw.trim();
  if (!url) return { kind: null, src: "" };

  // YouTube
  const yt =
    url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|v\/)|youtu\.be\/)([A-Za-z0-9_-]{6,})/);
  if (yt) {
    const id = yt[1];
    // Background-video params: autoplay, loop (via playlist), mute, no UI.
    const params = new URLSearchParams({
      autoplay: "1",
      mute: "1",
      loop: "1",
      playlist: id,
      controls: "0",
      showinfo: "0",
      rel: "0",
      modestbranding: "1",
      playsinline: "1",
      iv_load_policy: "3",
    });
    return { kind: "youtube", src: `https://www.youtube.com/embed/${id}?${params.toString()}` };
  }

  // Vimeo
  const vm = url.match(/vimeo\.com\/(?:video\/)?(\d+)/);
  if (vm) {
    const id = vm[1];
    const params = new URLSearchParams({
      autoplay: "1",
      muted: "1",
      loop: "1",
      background: "1",
      controls: "0",
      playsinline: "1",
    });
    return { kind: "vimeo", src: `https://player.vimeo.com/video/${id}?${params.toString()}` };
  }

  // Treat anything else as a direct media URL (MP4/WebM/MOV). The
  // storefront <video> element will silently fail if the MIME can't be
  // decoded, and the poster image still shows — acceptable fallback.
  return { kind: "mp4", src: url };
}

const DEFAULT_HERO_SLIDES: HeroSlide[] = [
  {
    eyebrow: "New arrivals",
    headline: "Discover\nThe Collection",
    sub: "Curated physical goods, digital downloads and monthly boxes — all in one place.",
    cta: { label: "Shop now", href: "/shop" },
    bgType: "gradient",
    bgCss: "radial-gradient(ellipse at 70% 50%, #1a1000 0%, #0b0b0b 70%)",
    bgImage: null,
    bgFocal: "center",
    bgOverlay: "linear-gradient(90deg, rgba(11,11,11,.78) 0%, rgba(11,11,11,.35) 100%)",
    videoUrl: "",
    videoKind: null,
    videoPoster: null,
    accent: "linear-gradient(90deg, #c8a46e, #8b6520)",
  },
];

let heroSlides: HeroSlide[];
try {
  const { entries: slideEntries } = await getEmDashCollection("hero_slides");
  const mapped = slideEntries
    .slice()
    .sort((a, b) => {
      const oa = Number(a.data.sort_order ?? 0);
      const ob = Number(b.data.sort_order ?? 0);
      return oa - ob;
    })
    .map<HeroSlide>((e) => {
      // Smart background-type resolution.
      //
      // We intentionally IGNORE the `bg_type` dropdown when a richer medium
      // is actually populated — that way editors can just upload an image
      // (or paste a video URL) and the slide "does the right thing" even
      // if they forget to flip the selector. The explicit dropdown still
      // wins when no media is present, so a pure-gradient slide stays a
      // gradient.
      //
      // Priority: video URL → image → whatever the dropdown said (or
      // gradient as last resort).
      const videoUrl = String(e.data.bg_video_url ?? "").trim();
      const hasImage = Boolean(e.data.bg_image);
      const rawType = String(e.data.bg_type ?? "gradient");
      const bgType: BgType = videoUrl
        ? "video"
        : hasImage
          ? "image"
          : rawType === "image" || rawType === "video"
            ? "gradient" // user picked image/video but uploaded nothing → show gradient fallback
            : "gradient";
      const video = videoUrl
        ? parseVideo(videoUrl)
        : { kind: null as EmbedKind, src: "" };

      return {
        eyebrow: String(e.data.eyebrow ?? ""),
        headline: String(e.data.headline ?? ""),
        sub: String(e.data.subtitle ?? ""),
        cta: {
          label: String(e.data.cta_label ?? "Shop now"),
          href: String(e.data.cta_href ?? "/shop"),
        },
        bgType,
        bgCss: String(
          e.data.bg_css ?? "radial-gradient(ellipse at 70% 50%, #1a1000 0%, #0b0b0b 70%)",
        ),
        bgImage: e.data.bg_image ?? null,
        bgFocal: String(e.data.bg_focal_point ?? "center"),
        bgOverlay: String(
          e.data.bg_overlay ??
            "linear-gradient(90deg, rgba(11,11,11,.78) 0%, rgba(11,11,11,.35) 100%)",
        ),
        videoUrl: video.src,
        videoKind: video.kind,
        videoPoster: e.data.bg_video_poster ?? null,
        accent: String(
          e.data.accent_css ?? "linear-gradient(90deg, #c8a46e, #8b6520)",
        ),
      };
    })
    .filter((s) => s.headline.length > 0);
  heroSlides = mapped.length > 0 ? mapped : DEFAULT_HERO_SLIDES;
} catch {
  // Collection not yet seeded — the template renders the single
  // DEFAULT_HERO_SLIDES entry and the admin can add more later.
  heroSlides = DEFAULT_HERO_SLIDES;
}

// ── Bento categories (from `category_tiles` collection) ─────────────────────
// Editors manage this from `/_emdash/admin/content/category_tiles`. Each
// tile has: label + description + href + size + background + optional image.
let categories: Array<{
  label: string;
  desc: string;
  href: string;
  bg: string;
  size: "large" | "small";
  image: string | MediaValue | null;
}> = [];
try {
  const { entries } = await getEmDashCollection("category_tiles", {
    status: "published",
  });
  categories = entries
    .slice()
    .sort(
      (a, b) =>
        Number(a.data.sort_order ?? 999) - Number(b.data.sort_order ?? 999),
    )
    .map((e) => ({
      label: e.data.label ?? "",
      desc: e.data.description ?? "",
      href: e.data.href ?? "#",
      bg:
        e.data.bg_css ?? "linear-gradient(135deg, #2d1800 0%, #0b0b0b 100%)",
      size: (e.data.size === "small" ? "small" : "large") as "small" | "large",
      image: (e.data.image ?? null) as string | MediaValue | null,
    }));
} catch {
  categories = [];
}

// ── Trust strip items (from `trust_items` collection) ───────────────────────
let trustItems: Array<{ icon: string; title: string; desc: string }> = [];
try {
  const { entries } = await getEmDashCollection("trust_items", {
    status: "published",
  });
  trustItems = entries
    .slice()
    .sort(
      (a, b) =>
        Number(a.data.sort_order ?? 999) - Number(b.data.sort_order ?? 999),
    )
    .map((e) => ({
      icon: String(e.data.icon ?? "✦"),
      title: String(e.data.title ?? ""),
      desc: String(e.data.description ?? ""),
    }));
} catch {
  trustItems = [];
}

// ── Marquee strip (announcements where location = marquee or both) ─────────
let marqueeItems: string[] = [];
try {
  const { entries } = await getEmDashCollection("announcements", {
    status: "published",
  });
  marqueeItems = entries
    .filter((e) => {
      const loc = String(e.data.location ?? "top_bar");
      const enabled = e.data.enabled !== false;
      return enabled && (loc === "marquee" || loc === "both");
    })
    .sort(
      (a, b) =>
        Number(a.data.sort_order ?? 999) - Number(b.data.sort_order ?? 999),
    )
    .map((e) => String(e.data.message ?? ""))
    .filter((m) => m.length > 0);
} catch {
  marqueeItems = [];
}
// Duplicate for a seamless marquee loop.
const marqueeLoop = marqueeItems.length
  ? [...marqueeItems, ...marqueeItems]
  : [];

// Homepage section headers (Bento, Products, Journal) are now driven by
// the `section_headers` collection and rendered via the reusable
// <SectionHeader/> component further down, so we don't need to pre-resolve
// copy here any more. site_text.main has been slimmed down to just
// footer/global copy (see Footer.astro).
---

<Shop>
  {/* Homepage intentionally passes no `title` / `description` — Shop.astro
     falls back to `settings.title` and `settings.tagline` from Site Settings.
     This keeps the homepage in sync with whatever the editor has branded. */}

  <!-- ═══════════ HERO SLIDER ═══════════ -->
  <section class="hero-slider" aria-label="Featured collections">
    {heroSlides.map((slide, i) => (
      <div
        class={`hero-slide hero-bg-${slide.bgType}${i === 0 ? " active" : ""}`}
        aria-hidden={i !== 0}
        style={slide.bgType === "gradient" ? `background: ${slide.bgCss};` : undefined}
      >
        <!-- Background media layer (image or video). Sits under the overlay + content. -->
        {slide.bgType === "image" && slide.bgImage && (
          <div class="hero-bg-media">
            <Image
              image={slide.bgImage}
              alt=""
              class="hero-bg-img"
              loading={i === 0 ? "eager" : "lazy"}
              decoding="async"
              style={`object-position: ${slide.bgFocal};`}
            />
          </div>
        )}
        {slide.bgType === "video" && slide.videoKind === "mp4" && slide.videoUrl && (
          <div class="hero-bg-media">
            <video
              class="hero-bg-video"
              src={slide.videoUrl}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-hidden="true"
            >
              {slide.videoPoster && (
                <Image image={slide.videoPoster} alt="" class="hero-bg-img" />
              )}
            </video>
          </div>
        )}
        {slide.bgType === "video" && (slide.videoKind === "youtube" || slide.videoKind === "vimeo") && slide.videoUrl && (
          <div class="hero-bg-media hero-bg-embed">
            <iframe
              class="hero-bg-iframe"
              src={slide.videoUrl}
              title=""
              aria-hidden="true"
              tabindex="-1"
              allow="autoplay; fullscreen; picture-in-picture"
              frameborder="0"
              loading={i === 0 ? "eager" : "lazy"}
            ></iframe>
          </div>
        )}

        <!-- Legibility overlay (applied on top of image/video only) -->
        {(slide.bgType === "image" || slide.bgType === "video") && (
          <div class="hero-bg-overlay" style={`background: ${slide.bgOverlay};`}></div>
        )}

        <!-- Accent bar -->
        <div class="hero-accent-bar" style={`background: ${slide.accent};`}></div>

        <div class="container hero-slide-inner">
          <div class="hero-copy">
            <p class="hero-eyebrow">{slide.eyebrow}</p>
            <h1 class="hero-headline">{slide.headline}</h1>
            <p class="hero-sub">{slide.sub}</p>
            <div class="hero-cta-row">
              <a href={slide.cta.href} class="btn-primary">{slide.cta.label}</a>
              <a href="/shop" class="btn-ghost">View all</a>
            </div>
          </div>

          <div class="hero-visual" aria-hidden="true">
            <div class="hero-visual-inner">
              <div class="hero-geo hero-geo-1"></div>
              <div class="hero-geo hero-geo-2"></div>
              <div class="hero-geo hero-geo-3"></div>
              {featured && (
                <a href={featuredSlug} class="hero-product-card">
                  <div class="hero-product-img" style={`background: ${featuredGrad};`}></div>
                  <div class="hero-product-body">
                    <span class="hero-product-type">{featuredType}</span>
                    <strong class="hero-product-title">{featuredTitle}</strong>
                    <span class="hero-product-price">{featuredPrice ?? "—"}</span>
                  </div>
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    ))}

    <!-- Slide controls -->
    <div class="hero-controls" role="tablist" aria-label="Slide navigation">
      {heroSlides.map((_, i) => (
        <button
          class={`hero-dot${i === 0 ? " active" : ""}`}
          role="tab"
          aria-selected={i === 0}
          aria-label={`Slide ${i + 1}`}
          data-slide={i}
        ></button>
      ))}
    </div>

    <!-- Progress bar -->
    <div class="hero-progress" aria-hidden="true">
      <div class="hero-progress-fill"></div>
    </div>
  </section>

  <!-- ═══════════ MARQUEE ═══════════ -->
  {marqueeLoop.length > 0 && (
    <div class="marquee-strip" aria-hidden="true">
      <div class="marquee-track">
        {marqueeLoop.map((t, i, a) => (
          <>
            <span class="marquee-item">{t}</span>
            {i < a.length - 1 && <span class="marquee-sep">✦</span>}
          </>
        ))}
      </div>
    </div>
  )}

  <!-- ═══════════ CATEGORIES BENTO ═══════════ -->
  {categories.length > 0 && (
    <>
      <SectionHeader
        slug="homepage-bento"
        fallbackEyebrow="Browse by type"
        fallbackTitle={`Everything you need,\nin one place`}
      />
      <section class="section container section-bento-grid">
        <div class="bento-grid">
          {categories.map((cat) => (
            <a
              href={cat.href}
              class={`bento-tile bento-${cat.size}`}
              style={`background: ${cat.bg};`}
            >
              {cat.image && (
                <Image image={cat.image} alt="" class="bento-img" loading="lazy" />
              )}
              <div class="bento-overlay"></div>
              <div class="bento-body">
                <p class="bento-desc">{cat.desc}</p>
                <strong class="bento-label">{cat.label}</strong>
                <span class="bento-arrow">→</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    </>
  )}

  <!-- ═══════════ PRODUCT GRID ═══════════ -->
  {products.length > 0 ? (
    <section class="section container">
      <SectionHeader
        slug="homepage-products"
        fallbackEyebrow="The selection"
        fallbackTitle={`New in\nthis season`}
        ctaLabelOverride={`View all ${products.length} products`}
        fallbackCtaHref="/shop"
      />

      <div class="product-grid">
        {recentCards.map((c) => (
          <a href={c.href} class="product-card" aria-label={`${c.title}${c.price ? ` — ${c.price}` : ""}`}>
            <div class="product-card-img" style={`background: ${c.grad};`}>
              {c.isOut  && <span class="product-badge-out">Sold out</span>}
              {c.isFeat && <span class="product-badge-feat">Featured</span>}
              <div class="product-card-img-overlay"></div>
            </div>
            <div class="product-card-body">
              <span class="product-card-type">{c.type}</span>
              <h3 class="product-card-title">{c.title}</h3>
              {c.price
                ? <span class="product-card-price">{c.price}</span>
                : <span class="product-card-price product-card-na">—</span>
              }
            </div>
            <div class="product-card-hover">
              <span>View product →</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  ) : (
    <section class="section container">
      <div class="empty-state">
        <div class="empty-icon" aria-hidden="true">✦</div>
        <h2>Your shop is empty</h2>
        <p>Run <code>bun run seed</code> to load the demo catalog, or create your first product in the admin.</p>
        <a href="/_emdash/admin/content/products/new" class="btn-primary">Create a product</a>
      </div>
    </section>
  )}

  <!-- ═══════════ MID BANNER (managed via Banners collection) ═══════════ -->
  <Banner slug="home-promise" />

  <!-- ═══════════ FROM THE JOURNAL ═══════════ -->
  {journalPosts.length > 0 && (
    <section class="journal-strip">
      <div class="container">
        <SectionHeader
          slug="homepage-journal"
          fallbackEyebrow="The Journal"
          fallbackTitle="From the editors"
          fallbackSubtitle="Product stories, buying guides, and notes from the workshop."
          fallbackCtaLabel="View all posts"
          fallbackCtaHref="/blog"
        />

        <ul class="journal-grid" role="list">
          {journalPosts.map((p) => (
            <li>
              <a href={p.href} class="journal-card" aria-label={p.title}>
                <div class="journal-card-img" style={`background: ${p.gradient};`}>
                  {p.cover && (
                    <Image image={p.cover} alt="" class="journal-card-cover" loading="lazy" />
                  )}
                </div>
                <div class="journal-card-body">
                  <p class="journal-card-kicker">{p.category}</p>
                  <h3 class="journal-card-title">{p.title}</h3>
                  {p.excerpt && <p class="journal-card-excerpt">{p.excerpt}</p>}
                  <div class="journal-card-meta">
                    {p.date && <span>{p.date}</span>}
                    {p.minutes > 0 && <span>{p.minutes} min read</span>}
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- ═══════════ TRUST STRIP ═══════════ -->
  {trustItems.length > 0 && (
    <section class="trust-strip">
      <div class="container trust-inner">
        {trustItems.map((ti) => (
          <div class="trust-item">
            <span class="trust-icon" aria-hidden="true">{ti.icon}</span>
            <div>
              <strong class="trust-title">{ti.title}</strong>
              <p class="trust-desc">{ti.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

</Shop>

<style>
  /* ── Hero Slider ── */
  .hero-slider {
    position: relative;
    height: 92vh;
    min-height: 600px;
    max-height: 900px;
    overflow: hidden;
  }

  .hero-slide {
    position: absolute; inset: 0;
    display: flex; align-items: center;
    opacity: 0;
    transition: opacity .8s var(--ease);
    pointer-events: none;
    overflow: hidden;
    background-color: #0b0b0b;
  }
  .hero-slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Background media layer: image or video sits beneath content. */
  .hero-bg-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .hero-bg-img,
  .hero-bg-video,
  .hero-bg-iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  /* YouTube/Vimeo iframes can't be `object-fit`'d — we blow them up past
     the viewport so the video fills the container without letterboxing,
     and clip the overflow on the parent. 177.77vh keeps a 16:9 video
     filling the width of any viewport; max() does the same for tall
     screens. */
  .hero-bg-embed { pointer-events: none; }
  .hero-bg-iframe {
    position: absolute;
    top: 50%; left: 50%;
