<script>
  // Hero slider
  const slides  = Array.from(document.querySelectorAll<HTMLElement>(".hero-slide"));
  const dots    = Array.from(document.querySelectorAll<HTMLButtonElement>(".hero-dot"));
  const fill    = document.querySelector<HTMLElement>(".hero-progress-fill");
  const INTERVAL = 6000;
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(n: number) {
    slides[current].classList.remove("active");
    slides[current].setAttribute("aria-hidden", "true");
    dots[current].classList.remove("active");
    dots[current].setAttribute("aria-selected", "false");
    current = ((n % slides.length) + slides.length) % slides.length;
    slides[current].classList.add("active");
    slides[current].setAttribute("aria-hidden", "false");
    dots[current].classList.add("active");
    dots[current].setAttribute("aria-selected", "true");
    if (fill) { fill.style.transition = "none"; fill.style.width = "0%"; requestAnimationFrame(() => { fill.style.transition = `width ${INTERVAL}ms linear`; fill.style.width = "100%"; }); }
  }

  function start() {
    if (slides.length <= 1) return;
    timer = setInterval(() => goTo(current + 1), INTERVAL);
    if (fill) { fill.style.transition = `width ${INTERVAL}ms linear`; fill.style.width = "100%"; }
  }
  function stop() { clearInterval(timer); if (fill) { fill.style.transition = "none"; fill.style.width = "0%"; } }

  dots.forEach((dot, i) => dot.addEventListener("click", () => { stop(); goTo(i); start(); }));

  const hero = document.querySelector<HTMLElement>(".hero-slider");
  hero?.addEventListener("mouseenter", stop);
  hero?.addEventListener("mouseleave", start);

  // Keyboard nav
  hero?.addEventListener("keydown", (e) => {
    if (e.key === "ArrowLeft")  { stop(); goTo(current - 1); start(); }
    if (e.key === "ArrowRight") { stop(); goTo(current + 1); start(); }
  });

  goTo(0);
  start();
</script>
