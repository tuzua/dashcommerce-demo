---
import type { ContentEntry, MediaValue } from "emdash";
import type { Post } from "../../../../emdash-env";
import {
  getEntriesByTerm,
  getTaxonomyTerms,
  getTerm,
} from "emdash";
import { Image } from "emdash/ui";
import Shop from "../../../layouts/Shop.astro";

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return new Response("Category not found", { status: 404 });

const term = await getTerm("post_category", slug);
if (!term) return Astro.redirect("/blog", 302);

// getEntriesByTerm returns untyped entries; narrow to the Post shape
// declared in emdash-env.d.ts so field access stays type-safe.
const posts = (await getEntriesByTerm(
  "posts",
  "post_category",
  slug,
)) as unknown as ContentEntry<Post>[];

// Other categories for the chip row (keep current one labelled but not linked).
const allTerms = await getTaxonomyTerms("post_category");

const fmtDate = (raw: string | Date | undefined | null) => {
  if (!raw) return "";
  const d = raw instanceof Date ? raw : new Date(raw);
  if (Number.isNaN(d.getTime())) return "";
  return new Intl.DateTimeFormat("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  }).format(d);
};

// Per-category background tint. Falls back to a neutral radial.
const catBg: Record<string, string> = {
  "behind-the-scenes": "radial-gradient(ellipse at 40% 50%, #2d1800 0%, #0b0b0b 70%)",
  "product-stories":   "radial-gradient(ellipse at 60% 50%, #1a001f 0%, #0b0b0b 70%)",
  "buying-guides":     "radial-gradient(ellipse at 50% 50%, #001433 0%, #0b0b0b 70%)",
};
const bg = catBg[slug] ?? "radial-gradient(ellipse at 50% 50%, #1a1a1a 0%, #0b0b0b 70%)";

type Card = {
  href: string;
  title: string;
  excerpt: string;
  cover: string | MediaValue | null;
  gradient: string;
  date: string;
  minutes: number;
  author: string;
};

const sortKey = (p: ContentEntry<Post>) =>
  p.data.published_date ?? p.data.publishedAt?.toISOString() ?? "";
const sorted = posts
  .slice()
  .sort((a, b) => sortKey(b).localeCompare(sortKey(a)));

const cards: Card[] = sorted.map((p) => ({
  href: `/blog/${p.data.slug ?? p.id}`,
  title: p.data.title ?? "",
  excerpt: p.data.excerpt ?? "",
  cover: p.data.cover_image ?? null,
  gradient:
    p.data.cover_gradient ??
    "linear-gradient(135deg, #2d1800 0%, #0b0b0b 100%)",
  date: fmtDate(p.data.published_date ?? p.data.publishedAt),
  minutes: p.data.reading_minutes ?? 0,
  author: p.data.author_name ?? "",
}));
---

<Shop
  title={`${term.label} · Journal`}
  description={term.description ?? `Posts filed under ${term.label}.`}
>
  <!-- Hero -->
  <section class="blog-hero" style={`background: ${bg};`}>
    <div class="container blog-hero-inner">
      <nav class="article-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/blog">Journal</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">{term.label}</span>
      </nav>
      <p class="blog-eyebrow">Category</p>
      <h1 class="blog-title">{term.label}</h1>
      {term.description && <p class="blog-sub">{term.description}</p>}
      <div class="blog-count">
        {cards.length} {cards.length === 1 ? "post" : "posts"}
      </div>
    </div>
  </section>

  <!-- Chips -->
  <div class="blog-nav-strip">
    <div class="container blog-nav-inner">
      <span class="blog-nav-label">Filter</span>
      <a href="/blog" class="blog-chip">All</a>
      {allTerms.map((t) =>
        t.slug === slug ? (
          <span class="blog-chip is-active">{t.label}</span>
        ) : (
          <a href={`/blog/category/${t.slug}`} class="blog-chip">{t.label}</a>
        ),
      )}
    </div>
  </div>

  <!-- Grid -->
  <div class="container blog-body">
    {cards.length === 0 ? (
      <div class="blog-empty">
        <div class="blog-empty-icon" aria-hidden="true">✦</div>
        <h2>No posts in this category yet</h2>
        <p>
          Check back soon, or <a href="/blog">browse all posts</a>.
        </p>
      </div>
    ) : (
      <ul class="blog-grid" role="list">
        {cards.map((c) => (
          <li>
            <a href={c.href} class="blog-card" aria-label={c.title}>
              <div class="blog-card-img" style={`background: ${c.gradient};`}>
                {c.cover && (
                  <Image image={c.cover} alt="" class="blog-card-cover" loading="lazy" />
                )}
                <div class="blog-card-view">Read →</div>
              </div>
              <div class="blog-card-body">
                <h3 class="blog-card-title">{c.title}</h3>
                {c.excerpt && <p class="blog-card-excerpt">{c.excerpt}</p>}
                <div class="blog-card-meta">
                  {c.author && <span>{c.author}</span>}
                  {c.date && <span>{c.date}</span>}
                  {c.minutes > 0 && <span>{c.minutes} min</span>}
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Shop>

<style>
  .blog-hero {
    padding: 5rem 0 3.5rem;
    border-bottom: 1px solid var(--border);
    min-height: 300px;
    display: flex; align-items: flex-end;
  }
  .blog-hero-inner { width: 100%; max-width: 800px; }
  .article-breadcrumb {
    display: flex; align-items: center; gap: .5rem;
    font-size: .8rem; color: var(--text-muted);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .article-breadcrumb a { color: var(--text-muted); transition: color .2s; text-decoration: none; }
  .article-breadcrumb a:hover { color: var(--gold); }
  .article-breadcrumb [aria-current] { color: var(--text-mid); }
  .blog-eyebrow {
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 1rem;
  }
  .blog-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    letter-spacing: -.02em;
    color: var(--text);
    margin: 0 0 1rem;
  }
  .blog-sub {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 52ch;
    margin: 0 0 1.5rem;
  }
  .blog-count {
    display: inline-block;
    font-size: .74rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--text-subtle);
    font-weight: 600;
    padding: .3rem .75rem;
    border: 1px solid var(--border-mid);
    border-radius: 100px;
  }

  .blog-nav-strip {
    background: var(--bg-2);
    border-bottom: 1px solid var(--border);
    padding: .875rem 0;
  }
  .blog-nav-inner { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
  .blog-nav-label {
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--text-subtle);
    font-weight: 600;
    margin-right: .5rem;
  }
  .blog-chip {
    font-size: .82rem;
    color: var(--text-muted);
    padding: .35rem .8rem;
    border-radius: 100px;
    border: 1px solid var(--border);
    transition: color .2s, border-color .2s, background .2s;
    text-decoration: none;
  }
  .blog-chip:hover { color: var(--text); border-color: var(--border-mid); }
  .blog-chip.is-active { color: #0b0b0b; background: var(--gold); border-color: var(--gold); }

  .blog-body { padding: 3rem 0 6rem; }
  .blog-grid {
    list-style: none; margin: 0; padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem 1.75rem;
  }
  .blog-card {
    display: flex; flex-direction: column;
    text-decoration: none; color: inherit;
    transition: transform .25s var(--ease);
  }
  .blog-card:hover { transform: translateY(-3px); }
  .blog-card-img {
    position: relative;
    aspect-ratio: 4/3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 1.25rem;
  }
  .blog-card-cover {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
  .blog-card-view {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(11,11,11,.7);
    font-size: .875rem; font-weight: 600;
    color: var(--gold); letter-spacing: .04em;
    opacity: 0;
    transition: opacity .25s;
  }
  .blog-card:hover .blog-card-view { opacity: 1; }
  .blog-card-body { display: flex; flex-direction: column; gap: .5rem; }
  .blog-card-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    line-height: 1.3;
    color: var(--text);
    margin: 0;
    transition: color .2s;
  }
  .blog-card:hover .blog-card-title { color: var(--gold); }
  .blog-card-excerpt {
    font-size: .9rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card-meta {
    display: flex; gap: .75rem;
    font-size: .75rem;
    color: var(--text-subtle);
    margin-top: .25rem;
  }
  .blog-card-meta span + span::before {
    content: "·";
    margin-right: .75rem;
    color: var(--border-mid);
  }

  .blog-empty { padding: 5rem 1rem; text-align: center; max-width: 420px; margin: 0 auto; }
  .blog-empty-icon { font-size: 2.25rem; color: var(--gold); opacity: .4; margin-bottom: 1.25rem; }
  .blog-empty h2 { margin-bottom: .75rem; }
  .blog-empty p { color: var(--text-muted); }
  .blog-empty a { color: var(--gold); }

  @media (max-width: 1000px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px)  { .blog-grid { grid-template-columns: 1fr; gap: 2rem; } }
</style>
