---
/**
 * Top-of-page announcement bar.
 *
 * Pulls messages from the `announcements` collection where
 *   - enabled = true AND
 *   - location ∈ {"top_bar", "both"}
 *
 * Messages are rendered as a seamless marquee. If the collection is empty
 * (fresh install or all entries disabled), the bar falls back to the
 * `messages` prop so the layout still renders something sensible.
 */
import { getEmDashCollection } from "emdash";

interface Props {
	messages?: string[];
}
const {
	messages: fallbackMessages = [
		"Free shipping on orders over $75",
		"30-day returns, no questions asked",
		"Secure checkout powered by Stripe",
	],
} = Astro.props;

interface AnnouncementItem {
	message: string;
	href: string | null;
}

let items: AnnouncementItem[] = [];
try {
	const { entries } = await getEmDashCollection("announcements", {
		status: "published",
	});
	items = entries
		.filter((e) => {
			const loc = String(e.data.location ?? "top_bar");
			const enabled = e.data.enabled !== false;
			return enabled && (loc === "top_bar" || loc === "both");
		})
		.sort(
			(a, b) =>
				Number(a.data.sort_order ?? 999) - Number(b.data.sort_order ?? 999),
		)
		.map((e) => ({
			message: String(e.data.message ?? ""),
			href: e.data.href ? String(e.data.href) : null,
		}))
		.filter((it) => it.message.length > 0);
} catch {
	items = [];
}
if (items.length === 0) {
	items = fallbackMessages.map((m) => ({ message: m, href: null }));
}

// Duplicate for seamless loop.
const all = [...items, ...items];
---

{items.length > 0 && (
	<div class="ann-bar" role="banner" aria-label="Site announcements">
		<div class="ann-track" aria-hidden="true">
			{all.map((it, i) => (
				<>
					{it.href ? (
						<a href={it.href} class="ann-msg ann-msg-link">{it.message}</a>
					) : (
						<span class="ann-msg">{it.message}</span>
					)}
					{i < all.length - 1 && <span class="ann-sep" aria-hidden="true">✦</span>}
				</>
			))}
		</div>
		<p class="sr-only">{items[0].message}</p>
	</div>
)}

<style>
  .ann-bar {
    background: #111111;
    background: var(--bg-2);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    border-bottom: 1px solid var(--border);
    height: 36px;
    overflow: hidden;
    position: relative;
  }
  .ann-track {
    display: flex;
    align-items: center;
    gap: 2rem;
    white-space: nowrap;
    animation: marquee 40s linear infinite;
    height: 100%;
    will-change: transform;
  }
  .ann-bar:hover .ann-track { animation-play-state: paused; }
  .ann-msg {
    font-size: .78rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: #b5b0a7;
    color: var(--text-mid);
    font-weight: 500;
    text-decoration: none;
  }
  .ann-msg-link { transition: color .2s; }
  .ann-msg-link:hover { color: var(--gold); }
  .ann-sep {
    color: #c8a46e;
    color: var(--gold);
    font-size: .6rem;
    opacity: .7;
    flex-shrink: 0;
  }
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
